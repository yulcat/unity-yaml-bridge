{
  "name": "unity-yaml-bridge",
  "version": "1.0.1",
  "description": "Bidirectional parser between Unity YAML and AI-friendly .ubridge format",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ubridge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "tsc && node dist/test-roundtrip.js && node dist/test-compact-roundtrip.js && node dist/test-refs.js && node dist/test-path-refs.js && node dist/test-variant-issues.js",
    "test:roundtrip": "tsc && node dist/test-roundtrip.js",
    "test:compact": "tsc && node dist/test-compact-roundtrip.js",
    "test:refs": "tsc && node dist/test-refs.js"
  },
  "keywords": [
    "unity",
    "yaml",
    "prefab",
    "ai",
    "parser",
    "gamedev"
  ],
  "author": "yulcat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yulcat/unity-yaml-bridge.git"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist/",
    "docs/",
    "README.md"
  ]
}
